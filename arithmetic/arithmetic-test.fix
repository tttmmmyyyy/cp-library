module CPLib.Arithmetic.Test;

import BoolArray::BoolArray::@;
import CPLib.Arithmetic::{
    add_mod, calc_gcd, create_prime_list, create_prime_table, ext_gcd, factorize, factorize_flat, 
    factorize_via_lp_table, inv_mod, is_prime, is_prime_32, isqrt, lift_crt, linear_sieve, mul_mod, pmod, 
    pow_mod, pythagorean_triples, sub_mod, _calc_primitive_root, _inv_gcd
};
import Random::{generate_I64_nonneg, generate_U64, init_by_seed};
import Std::{
    loop, IO, U64, Array::{get_size, sort, to_iter, @}, 
    Debug::{assert, assert_eq, consumed_time_while_lazy}, Functor::{forget, map}, I32::maximum, 
    I64::{maximum, minimum, shift_left}, IO::println, Iterator::{collect_m, filter, fold_m, map, range}, 
    LessThan::max, LoopState::{break, continue}, Monad::pure, String::populate, ToI64::i64, 
    ToString::to_string, ToU32::u32, ToU64::u64, U32::shift_left, U64::{maximum, shift_left}
};

// floor_math:
// https://atcoder.jp/contests/language-test-202505/submissions/68412909 

test : IO ();
test = (
    test_pmod;;
    test_mod_arithmetic;;
    test_isqrt;;
    test_gcd;;
    test_ext_gcd;;
    test_pow_mod;;
    test_inv_mod;;
    test_prime_table;;
    test_prime_list;;
    test_linear_sieve;;
    test_factorize_via_lp_table;;
    test_factorize_flat;;
    test_factorize;;
    test_miller_rabin_u64;;
    test_miller_rabin_u32;;
    test_inv_gcd;;
    test_crt;;
    test_calc_primitive_root;;
    test_pythagorean_triples;;

    pure()
);

test_pmod : IO ();
test_pmod = (
    assert_eq(|_|"pmod 1", 12.pmod(5), 2);;
    assert_eq(|_|"pmod 4", -12.pmod(5), 3);;
    assert_eq(|_|"pmod 5", 0.pmod(5), 0);;
    assert_eq(|_|"pmod 6", I64::maximum.pmod(I64::maximum), 0);;
    assert_eq(|_|"pmod 7", I64::minimum.pmod(I64::maximum), I64::maximum-1);;

    pure()
);

test_mod_arithmetic : IO ();
test_mod_arithmetic = (
    assert_eq(|_|"add_mod 1", add_mod(I64::maximum, I64::maximum, I64::maximum), 0);;
    assert_eq(|_|"add_mod 2", add_mod(I64::minimum, I64::minimum, I64::maximum), I64::maximum-2);;
    assert_eq(|_|"add_mod 3", add_mod(I64::minimum, I64::maximum, I64::maximum), I64::maximum-1);;

    assert_eq(|_|"sub_mod 1", sub_mod(I64::maximum, I64::maximum, I64::maximum), 0);;
    assert_eq(|_|"sub_mod 2", sub_mod(I64::minimum, I64::minimum, I64::maximum), 0);;
    assert_eq(|_|"sub_mod 3", sub_mod(I64::minimum, I64::maximum, I64::maximum), I64::maximum-1);;
    assert_eq(|_|"sub_mod 4", sub_mod(I64::maximum, I64::minimum, I64::maximum), 1);;
    assert_eq(|_|"sub_mod 5", sub_mod(I64::maximum, 0, I64::maximum), 0);;
    assert_eq(|_|"sub_mod 6", sub_mod(0, I64::maximum, I64::maximum), 0);;
    assert_eq(|_|"sub_mod 7", sub_mod(0, I64::minimum, I64::maximum), 1);;
    assert_eq(|_|"sub_mod 8", sub_mod(I64::minimum, 0, I64::maximum), I64::maximum-1);;

    assert_eq(|_|"mul_mod 1", mul_mod(I64::maximum, I64::maximum, I64::maximum), 0);;
    assert_eq(|_|"mul_mod 2", mul_mod(I64::minimum, I64::minimum, I64::maximum), 1);;
    assert_eq(|_|"mul_mod 3", mul_mod(I64::minimum, I64::maximum, I64::maximum), 0);;

    pure()
);

test_isqrt : IO ();
test_isqrt = (
    let isqrt_bs : U64 -> U64 = |x| (
        loop((0_U64, U64::maximum), |(l, r)|
            // l*l <= x < r*r
            if r - l <= 1_U64 { break $ l };
            let m = l + (r - l) / 2_U64;
            continue $ if m <= x / m {
                (m, r)
            } else {
                (l, m)
            }
        )
    );

    assert_eq(|_|"isqrt 1", isqrt(0_U64), 0_U64);;
    assert_eq(|_|"isqrt 2", isqrt(1_U64), 1_U64);;
    assert_eq(|_|"isqrt 2", isqrt(2_U64), 1_U64);;
    assert_eq(|_|"isqrt 3", isqrt(3_U64), 1_U64);;
    assert_eq(|_|"isqrt 4", isqrt(4_U64), 2_U64);;
    assert_eq(|_|"isqrt 5", isqrt(5_U64), 2_U64);;
    assert_eq(|_|"isqrt 5", isqrt(2000000_U64), 1414_U64);;
    assert_eq(|_|"isqrt 5", isqrt(U64::maximum), (1.shift_left(32) - 1).u64);;

    pure()
);

test_gcd : IO ();
test_gcd = (
    assert_eq(|_|"gcd 1", calc_gcd(12, 15), 3);;
    assert_eq(|_|"gcd 1", calc_gcd(-12, 15), 3);;
    assert_eq(|_|"gcd 2", calc_gcd(12, -15), 3);;
    assert_eq(|_|"gcd 3", calc_gcd(-12, -15), 3);;
    assert_eq(|_|"gcd 4", calc_gcd(0, 15), 15);;
    assert_eq(|_|"gcd 5", calc_gcd(15, 0), 15);;
    assert_eq(|_|"gcd 6", calc_gcd(0, 0), 0);;
    assert_eq(|_|"gcd 7", calc_gcd(17, 19), 1);;
    assert_eq(|_|"gcd 8", calc_gcd(17, 17), 17);;

    pure()
);

test_ext_gcd : IO ();
test_ext_gcd = (
    let (d, (x, y)) = ext_gcd(12, 15);
    assert_eq(|_|"ext_gcd 1a", d, 3);;
    assert_eq(|_|"ext_gcd 1b", x * 12 + y * 15, d);;

    let (d, (x, y)) = ext_gcd(-12, 15);
    assert_eq(|_|"ext_gcd 2a", d, 3);;
    assert_eq(|_|"ext_gcd 2b", x * -12 + y * 15, d);; 

    let (d, (x, y)) = ext_gcd(12, -15);
    assert_eq(|_|"ext_gcd 3a", d, 3);;
    assert_eq(|_|"ext_gcd 3b", x * 12 + y * -15, d);;

    let (d, (x, y)) = ext_gcd(-12, -15);
    assert_eq(|_|"ext_gcd 4a", d, 3);;
    assert_eq(|_|"ext_gcd 4b", x * -12 + y * -15, d);;

    let (d, (x, y)) = ext_gcd(0, 15);
    assert_eq(|_|"ext_gcd 5a", d, 15);;
    assert_eq(|_|"ext_gcd 5b", x * 0 + y * 15, d);;

    let (d, (x, y)) = ext_gcd(15, 0);
    assert_eq(|_|"ext_gcd 6a", d, 15);;
    assert_eq(|_|"ext_gcd 6b", x * 15 + y * 0, d);;

    let (d, (x, y)) = ext_gcd(0, 0);
    assert_eq(|_|"ext_gcd 7a", d, 0);;
    assert_eq(|_|"ext_gcd 7b", x * 0 + y * 0, d);;

    let (d, (x, y)) = ext_gcd(17, 19);
    assert_eq(|_|"ext_gcd 8a", d, 1);;
    assert_eq(|_|"ext_gcd 8b", x * 17 + y * 19, d);;

    let (d, (x, y)) = ext_gcd(17, 17);
    assert_eq(|_|"ext_gcd 9a", d, 17);;
    assert_eq(|_|"ext_gcd 9b", x * 17 + y * 17, d);;

    pure()
);

test_pow_mod : IO ();
test_pow_mod = (
    // 基本的なケース
    assert_eq(|_|"pow_mod 1 (5^2 mod 3)", 5.pow_mod(2, 3), 1);; // 5^2 = 25, 25 mod 3 = 1
    assert_eq(|_|"pow_mod 2 (5^3 mod 4)", 5.pow_mod(3, 4), 1);; // 5^3 = 125, 125 mod 4 = 1
    assert_eq(|_|"pow_mod 3 (2^10 mod 7)", 2.pow_mod(10, 7), 2);; // 2^10 = 1024, 1024 mod 7 = 2
    assert_eq(|_|"pow_mod 4 (0^5 mod 10)", 0.pow_mod(5, 10), 0);; // 0^5 = 0, 0 mod 10 = 0
    assert_eq(|_|"pow_mod 5 (any^0 mod any)", 123.pow_mod(0, 456), 1);; // 指数0の場合、常に1

    // 負の底のテスト (pmodの振る舞いによる)
    assert_eq(|_|"pow_mod 6 (-5^2 mod 3)", (-5).pow_mod(2, 3), 1);; // (-5)^2 = 25, 25 mod 3 = 1
    assert_eq(|_|"pow_mod 7 (-2^3 mod 5)", (-2).pow_mod(3, 5), 2);; // (-2)^3 = -8, -8 mod 5 = 2

    // 法が1の場合のテスト
    assert_eq(|_|"pow_mod 8 (any^any mod 1)", 7.pow_mod(100, 1), 0);; // mod 1 は常に0

    // オーバーフローに着目したテスト
    let max = I32::maximum.i64;
    assert_eq(|_|"pow_mod 9 (large x, e, m)", (max - 1).pow_mod(2, max), (max - 1) * (max - 1) % max);;
    assert_eq(|_|"pow_mod 10 (large x, e, small m)", max.pow_mod(10, 2), 1);;
    assert_eq(|_|"pow_mod 11 (large x, large m)", (max / 2).pow_mod(3, max / 3), (((max / 2) * (max / 2)) % (max / 3) * (max / 2)) % (max / 3));;

    // 特殊なケース
    assert_eq(|_|"pow_mod 12 (0^0 mod any)", 0.pow_mod(0, 5), 1);;

    pure()
);

test_inv_mod : IO ();
test_inv_mod = (
    let m = 17;
    range(-30, 30).filter(|x| x.pmod(m) != 0).fold_m((), |a, _|
        let x = a.inv_mod(m);
        let ax = (a * x).pmod(m);
        assert_eq(|_|"test_inv_mod ax mod m - 1, x = " + x.to_string, ax, 1);;
        assert(|_|"test_inv_mod 0 <= x < m, x = " + x.to_string, 0 <= x && x < m);;
        pure()
    );;
    pure()
);

test_prime_table : IO ();
test_prime_table = (
    let prime_table = create_prime_table(20);
    assert_eq(|_|"test_prime_table 0", prime_table.@(0), false);;
    assert_eq(|_|"test_prime_table 1", prime_table.@(1), false);;
    assert_eq(|_|"test_prime_table 2", prime_table.@(2), true);;
    assert_eq(|_|"test_prime_table 3", prime_table.@(3), true);;
    assert_eq(|_|"test_prime_table 4", prime_table.@(4), false);;
    assert_eq(|_|"test_prime_table 5", prime_table.@(5), true);;
    assert_eq(|_|"test_prime_table 6", prime_table.@(6), false);;
    assert_eq(|_|"test_prime_table 7", prime_table.@(7), true);;
    assert_eq(|_|"test_prime_table 8", prime_table.@(8), false);;
    assert_eq(|_|"test_prime_table 9", prime_table.@(9), false);;
    assert_eq(|_|"test_prime_table 10", prime_table.@(10), false);;
    assert_eq(|_|"test_prime_table 11", prime_table.@(11), true);;
    assert_eq(|_|"test_prime_table 12", prime_table.@(12), false);;
    assert_eq(|_|"test_prime_table 13", prime_table.@(13), true);;
    assert_eq(|_|"test_prime_table 14", prime_table.@(14), false);;
    assert_eq(|_|"test_prime_table 15", prime_table.@(15), false);;
    assert_eq(|_|"test_prime_table 16", prime_table.@(16), false);;
    assert_eq(|_|"test_prime_table 17", prime_table.@(17), true);;
    assert_eq(|_|"test_prime_table 18", prime_table.@(18), false);;
    assert_eq(|_|"test_prime_table 19", prime_table.@(19), true);;
    pure()
);

test_prime_list : IO ();
test_prime_list = (
    let n = 1e8;
    assert_eq(|_|"test_prime_list 1", create_prime_list(20).map(i64), [2, 3, 5, 7, 11, 13, 17, 19]);;
    let (res, time) = consumed_time_while_lazy(|_| create_prime_list(n));

    assert_eq(|_|"test_prime_list 2", res.get_size, 5761455);;
    println $ "[CPLib.Arithmetic.Test] create_prime_list({}): {}".populate([n.to_string, time.to_string]);;
    pure()
);

test_miller_rabin_u64 : IO ();
test_miller_rabin_u64 = (
    let _N = 1e5;
    let prime_table = create_prime_table(_N);
    range(0, _N).fold_m((), |n, _|
        assert_eq(|_|"check_is_prime_u64: " + n.to_string, prime_table.@(n), is_prime(n.u64))
    );;
    assert_eq(|_|"2^61-1 is prime", is_prime(1_U64.shift_left(61_U64) - 1_U64), true);;
    assert_eq(|_|"2^59-1 is not prime", is_prime(1_U64.shift_left(59_U64) - 1_U64), false);;
    pure()
);

test_miller_rabin_u32 : IO ();
test_miller_rabin_u32 = (
    let _N = 1e5;
    let prime_table = create_prime_table(_N);
    range(0, _N).fold_m((), |n, _|
        assert_eq(|_|"check_is_prime_u32: " + n.to_string, prime_table.@(n), is_prime_32(n.u32))
    );;
    assert_eq(|_|"2^31-1 is prime", is_prime_32(1_U32.shift_left(31_U32) - 1_U32), true);;
    assert_eq(|_|"2^29-1 is not prime", is_prime_32(1_U32.shift_left(29_U32) - 1_U32), false);;
    pure()
);

test_inv_gcd : IO ();
test_inv_gcd = (
    let _N = 1e3;
    let rng = Random::init_by_seed(0_U64);
    range(0, _N).fold_m(rng, |_, rng|
        let (rng, a) = rng.generate_U64;
        let a = a.i64;
        let (rng, b) = rng.generate_I64_nonneg;
        let b = if b == I64::maximum { 1 } else { b + 1 };        // b >= 1 にする
        let (g, x) = _inv_gcd(a, b);
        assert_eq(|_|"[test_inv_gcd] g = gcd(a, b)", g, calc_gcd(a, b));;
        assert_eq(|_|"[test_inv_gcd] xa = g (mod b)", mul_mod(x, a, b), g.pmod(b));;
        assert(|_|"[test_inv_gcd] 0 <= x < b/g", 0 <= x && x < b / g);;
        rng.pure
    ).forget;;
    pure()
);

test_crt : IO ();
test_crt = (
    let _N = 1e3;
    let rng = Random::init_by_seed(0_U64);
    range(0, _N).fold_m(rng, |_, rng|
        // 解がある場合のみチェック
        let (rng, m0) = rng.generate_I64_nonneg;
        let m0 = max(1, m0 % (I32::maximum.i64 - 1));
        let (rng, m1) = rng.generate_I64_nonneg;
        let m1 = max(1, m1 % (I32::maximum.i64 - 1));
        let (rng, x) = rng.generate_U64;
        let x = x.i64;
        let r0 = x.pmod(m0);
        let r1 = x.pmod(m1);
        // "{} {} {} {}".populate([r0, r1, m0, m1].map(to_string)).println;;
        let (y, z) = lift_crt([r0, r1], [m0, m1]);
        let lcm = m0 / calc_gcd(m0, m1) * m1;
        assert_eq(|_|"[test_crt] z is lcm", z, lcm);;
        assert_eq(|_|"[test_crt] y mod m0", y.pmod(m0), r0);;
        assert_eq(|_|"[test_crt] y mod m1", y.pmod(m1), r1);;
        rng.pure
    ).forget;;
    pure()
);

test_calc_primitive_root : IO ();
test_calc_primitive_root = (
    // TODO: add (999999999999999989, 3)
    [(2, 1), (3, 2), (5, 2), (7, 3), (11, 2), (13, 2), (17, 3), (19, 2), (1e9 + 7, 5), (998244353, 3)].to_iter.map(|(p, ans)|
        let r = _calc_primitive_root(p);
        assert_eq(|_|"[test_calc_primitive_root] {}".populate([p.to_string]), r, ans)
    ).collect_m;;
    pure()

);

test_pythagorean_triples : IO () = (
    assert_eq(|_|"pythagorean_triples 1", 
        pythagorean_triples(1).sort,
        []
    );;

    assert_eq(|_|"pythagorean_triples 2", 
        pythagorean_triples(2).sort,
        []
    );;

    assert_eq(|_|"pythagorean_triples 3", 
        pythagorean_triples(3).sort,
        []
    );;   

    assert_eq(|_|"pythagorean_triples 4", 
        pythagorean_triples(4).sort,
        []
    );; 


    assert_eq(|_|"pythagorean_triples 5", 
        pythagorean_triples(5).sort,
        [(3, 4, 5)]
    );;

    assert_eq(|_|"pythagorean_triples 25", 
        pythagorean_triples(25).sort,
        [(3, 4, 5), (15, 8, 17), (5, 12, 13), (7, 24, 25)].sort
    );;

    assert_eq(|_|"pythagorean_triples 101", 
        pythagorean_triples(101).sort,
        [(3, 4, 5), (15, 8, 17), (35, 12, 37), (63, 16, 65), (99, 20, 101), (5, 12, 13), (21, 20, 29), (45, 28, 53), (77, 36, 85), (7, 24, 25), (55, 48, 73), (9, 40, 41), (33, 56, 65), (65, 72, 97), (11, 60, 61), (39, 80, 89), (13, 84, 85)].sort
    );;    

    pure()
);

test_factorize_flat : IO ();
test_factorize_flat = (
    assert_eq(|_|"factorize_flat 1", factorize_flat(1), []);;
    assert_eq(|_|"factorize_flat 2", factorize_flat(2), [2_U32]);;
    assert_eq(|_|"factorize_flat 3", factorize_flat(3), [3_U32]);;
    assert_eq(|_|"factorize_flat 4", factorize_flat(4), [2_U32, 2_U32]);;
    assert_eq(|_|"factorize_flat 6", factorize_flat(6), [2_U32, 3_U32]);;
    assert_eq(|_|"factorize_flat 12", factorize_flat(12), [2_U32, 2_U32, 3_U32]);;
    assert_eq(|_|"factorize_flat 17", factorize_flat(17), [17_U32]);;
    assert_eq(|_|"factorize_flat 360", factorize_flat(360), [2_U32, 2_U32, 2_U32, 3_U32, 3_U32, 5_U32]);;
    // 平方数（d > n/d の境界ケース）
    assert_eq(|_|"factorize_flat 9", factorize_flat(9), [3_U32, 3_U32]);;
    assert_eq(|_|"factorize_flat 25", factorize_flat(25), [5_U32, 5_U32]);;
    assert_eq(|_|"factorize_flat 49", factorize_flat(49), [7_U32, 7_U32]);;
    assert_eq(|_|"factorize_flat 36", factorize_flat(36), [2_U32, 2_U32, 3_U32, 3_U32]);;
    assert_eq(|_|"factorize_flat 100", factorize_flat(100), [2_U32, 2_U32, 5_U32, 5_U32]);;
    assert_eq(|_|"factorize_flat 1018081", factorize_flat(1018081), [1009_U32, 1009_U32]);; // 1009^2, 1009 is prime
    // 大きめの素数
    assert_eq(|_|"factorize_flat 1000003", factorize_flat(1000003), [1000003_U32]);;
    // 大きめの合成数：1000000007 は素数なので、1000000007 * 2 = 2000000014
    assert_eq(|_|"factorize_flat 2000000014", factorize_flat(2000000014), [2_U32, 1000000007_U32]);;
    pure()
);

test_factorize : IO ();
test_factorize = (
    assert_eq(|_|"factorize 1", factorize(1), []);;
    assert_eq(|_|"factorize 2", factorize(2), [(2_U32, 1_U8)]);;
    assert_eq(|_|"factorize 4", factorize(4), [(2_U32, 2_U8)]);;
    assert_eq(|_|"factorize 6", factorize(6), [(2_U32, 1_U8), (3_U32, 1_U8)]);;
    assert_eq(|_|"factorize 12", factorize(12), [(2_U32, 2_U8), (3_U32, 1_U8)]);;
    assert_eq(|_|"factorize 243", factorize(243), [(3_U32, 5_U8)]);;
    assert_eq(|_|"factorize 360", factorize(360), [(2_U32, 3_U8), (3_U32, 2_U8), (5_U32, 1_U8)]);;
    // 平方数（d > n/d の境界ケース）
    assert_eq(|_|"factorize 9", factorize(9), [(3_U32, 2_U8)]);;
    assert_eq(|_|"factorize 25", factorize(25), [(5_U32, 2_U8)]);;
    assert_eq(|_|"factorize 49", factorize(49), [(7_U32, 2_U8)]);;
    assert_eq(|_|"factorize 36", factorize(36), [(2_U32, 2_U8), (3_U32, 2_U8)]);;
    assert_eq(|_|"factorize 100", factorize(100), [(2_U32, 2_U8), (5_U32, 2_U8)]);;
    assert_eq(|_|"factorize 81", factorize(81), [(3_U32, 4_U8)]);; // 3^4
    assert_eq(|_|"factorize 1018081", factorize(1018081), [(1009_U32, 2_U8)]);; // 1009^2
    assert_eq(|_|"factorize 1000003", factorize(1000003), [(1000003_U32, 1_U8)]);;
    assert_eq(|_|"factorize 2000000014", factorize(2000000014), [(2_U32, 1_U8), (1000000007_U32, 1_U8)]);;
    pure()
);

test_factorize_via_lp_table : IO ();
test_factorize_via_lp_table = (
    let (lp, _) = linear_sieve(400_U32);

    // n=0, n=1: 素因数なし
    assert_eq(|_|"factorize_via_lp_table 0", factorize_via_lp_table(0_U32, lp), []);;    
    assert_eq(|_|"factorize_via_lp_table 1", factorize_via_lp_table(1_U32, lp), []);;

    // 素数
    assert_eq(|_|"factorize_via_lp_table 2",  factorize_via_lp_table(2_U32, lp),  [(2_U32, 1_U8)]  );;
    assert_eq(|_|"factorize_via_lp_table 13", factorize_via_lp_table(13_U32, lp), [(13_U32, 1_U8)] );;

    // 素数の累乗
    assert_eq(|_|"factorize_via_lp_table 4",   factorize_via_lp_table(4_U32, lp),   [(2_U32, 2_U8)]            );;
    assert_eq(|_|"factorize_via_lp_table 8",   factorize_via_lp_table(8_U32, lp),   [(2_U32, 3_U8)]            );;
    assert_eq(|_|"factorize_via_lp_table 243", factorize_via_lp_table(243_U32, lp), [(3_U32, 5_U8)]            );; // 3^5

    // 複数の素因数
    assert_eq(|_|"factorize_via_lp_table 6",   factorize_via_lp_table(6_U32, lp),   [(2_U32, 1_U8), (3_U32, 1_U8)]              );;
    assert_eq(|_|"factorize_via_lp_table 12",  factorize_via_lp_table(12_U32, lp),  [(2_U32, 2_U8), (3_U32, 1_U8)]              );;
    assert_eq(|_|"factorize_via_lp_table 30",  factorize_via_lp_table(30_U32, lp),  [(2_U32, 1_U8), (3_U32, 1_U8), (5_U32, 1_U8)]);;
    assert_eq(|_|"factorize_via_lp_table 360", factorize_via_lp_table(360_U32, lp), [(2_U32, 3_U8), (3_U32, 2_U8), (5_U32, 1_U8)]);; // 2^3 * 3^2 * 5

    pure()
);

test_linear_sieve : IO ();
test_linear_sieve = (
    let (lp, ps) = linear_sieve(21_U32);

    assert_eq(|_|"case lp 0", lp.@(0), 0_U32);;
    assert_eq(|_|"case lp 1", lp.@(1), 0_U32);;
    assert_eq(|_|"case lp 2", lp.@(2), 2_U32);;
    assert_eq(|_|"case lp 3", lp.@(3), 3_U32);;
    assert_eq(|_|"case lp 4", lp.@(4), 2_U32);;
    assert_eq(|_|"case lp 5", lp.@(5), 5_U32);;
    assert_eq(|_|"case lp 6", lp.@(6), 2_U32);;
    assert_eq(|_|"case lp 7", lp.@(7), 7_U32);;
    assert_eq(|_|"case lp 8", lp.@(8), 2_U32);;
    assert_eq(|_|"case lp 9", lp.@(9), 3_U32);;
    assert_eq(|_|"case lp 10", lp.@(10), 2_U32);;
    assert_eq(|_|"case lp 11", lp.@(11), 11_U32);;
    assert_eq(|_|"case lp 12", lp.@(12), 2_U32);;
    assert_eq(|_|"case lp 13", lp.@(13), 13_U32);;
    assert_eq(|_|"case lp 14", lp.@(14), 2_U32);;
    assert_eq(|_|"case lp 15", lp.@(15), 3_U32);;
    assert_eq(|_|"case lp 16", lp.@(16), 2_U32);;
    assert_eq(|_|"case lp 17", lp.@(17), 17_U32);;
    assert_eq(|_|"case lp 18", lp.@(18), 2_U32);;
    assert_eq(|_|"case lp 19", lp.@(19), 19_U32);;
    assert_eq(|_|"case lp 20", lp.@(20), 2_U32);;
    assert_eq(|_|"case ps 0", ps.@(0), 2_U32);;
    assert_eq(|_|"case ps 1", ps.@(1), 3_U32);;
    assert_eq(|_|"case ps 2", ps.@(2), 5_U32);;
    assert_eq(|_|"case ps 3", ps.@(3), 7_U32);;
    assert_eq(|_|"case ps 4", ps.@(4), 11_U32);;
    assert_eq(|_|"case ps 5", ps.@(5), 13_U32);;
    assert_eq(|_|"case ps 6", ps.@(6), 17_U32);;
    assert_eq(|_|"case ps 7", ps.@(7), 19_U32);;

    pure()
);